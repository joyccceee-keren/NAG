# DoorPilot Environment Configuration

# ════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
PORT=3000
BASE_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════════════════════
# SMS PROVIDER CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
# Options: twilio, simulated
SMS_PROVIDER=simulated
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ════════════════════════════════════════════════════════════════════════════
# WHATSAPP CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
# Business phone number for WhatsApp messages
WHATSAPP_BUSINESS_NUMBER=919876543210

# Auto-initialize WhatsApp on server start (true/false)
WHATSAPP_AUTO_INIT=false

# ════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
DB_PATH=./data

# ════════════════════════════════════════════════════════════════════════════
# FEATURES
# ════════════════════════════════════════════════════════════════════════════
ENABLE_VOICE_NOTES=true
ENABLE_LANDMARKS=true
ENABLE_WHATSAPP=true
ENABLE_SMS=true
